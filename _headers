# Cloudflare Pages — per-path response headers.
# Format: https://developers.cloudflare.com/pages/configuration/headers/

# Force HTTPS for browsers that have seen this Pages deployment hostname before.
# Keep it host-only first; includeSubDomains/preload need a separate subdomain
# audit so we do not pin unknown future hosts under game-factory.tech.
/*
  Strict-Transport-Security: max-age=31536000

# Raw game folders (the static build outputs) should NOT be indexed.
# They're the actual iframe targets behind /play.html?slug=<X>; the
# canonical share landing for each game is /p/<slug> (which carries
# per-game JSON-LD + OG meta — commit Gallery#b2f9c20). Without this
# rule, Google may index /games/<slug>/ as a duplicate of /p/<slug>
# and /play.html?slug=X, creating 3 URLs per game = duplicate-content
# drag in Search Console's "Discovered – not indexed" bucket.
/games/*
  X-Robots-Tag: noindex

# Telegram Mini App wrapper: never serve a stale build. Telegram caches mini apps aggressively, so a fresh
# deploy (new shop UI, payments, config.js) can keep showing the OLD version on a player's device for a long
# time — this is what caused the 2026-06-30 "no TON button / Stars don't work" report. no-cache forces a
# conditional revalidation on every open (304 when unchanged = no re-download), so deploys land immediately
# without needing a ?v= cache-buster on the launch URL.
/tg-bloodtread/*
  Cache-Control: no-cache
